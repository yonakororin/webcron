{
  // ================================================================
  // webcron 設定ファイル
  // このファイルを config.json にコピーして環境に合わせて編集してください
  //   cp config.json.example config.json
  //
  // 動作モードは conf/env.sh の CONTAINER 変数で切り替えます:
  //   CONTAINER=""              → ホスト直接実行モード
  //   CONTAINER="コンテナ名"   → コンテナモード
  // ================================================================

  // ------------------------------------------------------------------
  // db_path: SQLite データベースファイルのパス
  //
  // [ホスト直接実行モード]
  //   PHP がホスト上で動くため、ホスト上の書き込み可能なパスを指定します。
  //   例: "/var/lib/webcron/cron.db"
  //
  // [コンテナモード]
  //   PHP がコンテナ内で動くため、コンテナ内から見たボリュームのパスを指定します。
  //   (ホスト上のパスではなく、コンテナ内のマウントパス)
  //   例: "/var/www/webcron-data/cron.db"
  //       (compose.yml で webcron-data ボリュームをマウントしている場合)
  //
  // ※ 相対パスも使用可能です。その場合は webcron ルートディレクトリ基準になります。
  //   例: "cron.db"
  // ------------------------------------------------------------------
  "db_path": "/var/lib/webcron/cron.db",

  // ------------------------------------------------------------------
  // updater_path: crontab 更新スクリプトのパス (通常変更不要)
  //   webcron ルートからの相対パスで指定します。
  // ------------------------------------------------------------------
  "updater_path": "./sh/deploy_cron.sh",

  // ------------------------------------------------------------------
  // host_runner: host_runner.sh のホスト上の絶対パス
  //
  // [ホスト直接実行モード / コンテナモード 共通]
  //   crontab に書き込まれ、ホスト上で直接実行されるため、
  //   どちらのモードでもホスト上の絶対パスを指定します。
  //   例: "/opt/webcron/sh/host_runner.sh"
  // ------------------------------------------------------------------
  "host_runner": "/opt/webcron/sh/host_runner.sh",

  // ------------------------------------------------------------------
  // crontab_dest: crontab ファイルの出力先 (ホスト上の絶対パス)
  //
  // [ホスト直接実行モード / コンテナモード 共通]
  //   どちらのモードでもホスト上のパスを指定します。
  //   通常は /etc/cron.d/ 以下を使用します。
  //
  // [コンテナモード の追加設定]
  //   コンテナから /etc/cron.d が参照できるよう compose.yml にボリューム追加が必要です:
  //     volumes:
  //       - /etc/cron.d:/etc/cron.d:ro
  // ------------------------------------------------------------------
  "crontab_dest": "/etc/cron.d/web_cron_jobs"
}
